---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE_NAME, SITE_URL, SITE_DESCRIPTION } from '~/consts';

const guides = (await getCollection('guides', ({ data }) => data.draft !== true))
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .slice(0, 4);

const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL + '/',
  description: SITE_DESCRIPTION,
  inLanguage: 'en',
  publisher: {
    '@type': 'Organization',
    name: SITE_NAME,
    url: SITE_URL + '/',
  },
};

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_NAME,
  url: SITE_URL + '/',
  description: SITE_DESCRIPTION,
};
---

<BaseLayout
  title="Format JSON, XML, HTML in Your Browser"
  description="Beautifier is a fast, privacy-respecting online toolkit to format, minify, and validate JSON, XML, and HTML. Nothing leaves your browser."
>
  <section class="hero container">
    <span class="privacy-badge" aria-label="Privacy">
      🔒 Your data never leaves your browser
    </span>
    <h1>Format code. Keep it private. Learn the format.</h1>
    <p class="tagline">
      Beautify, minify, and validate JSON — with XML and HTML coming soon.
      All parsing runs on your device. No uploads. No tracking of your inputs.
    </p>
    <div class="cta-row">
      <a class="btn btn-primary" href="/json/">Open JSON Beautifier</a>
      <a class="btn" href="/about/">Why this tool?</a>
    </div>
  </section>

  <section class="container">
    <h2 class="section-h">Available tools</h2>
    <div class="card-grid tools-grid">
      <a class="card tool-card" href="/json/">
        <h3>JSON</h3>
        <p>Beautify, minify, and validate JSON. Syntax errors with line and column. Sort keys alphabetically. Upload files up to 5&nbsp;MB.</p>
        <span class="card-arrow">Open →</span>
      </a>
      <a class="card tool-card" href="/xml/">
        <h3>XML</h3>
        <p>Format XML documents with CDATA, processing-instruction, and comment preservation. Validate via the browser's native parser.</p>
        <span class="card-arrow">Open →</span>
      </a>
      <a class="card tool-card" href="/html/">
        <h3>HTML</h3>
        <p>HTML5 beautifier that understands void elements and preserves <code>pre</code>, <code>script</code>, and <code>style</code> contents.</p>
        <span class="card-arrow">Open →</span>
      </a>
    </div>
  </section>

  <section class="container">
    <div class="card-grid reason-grid">
      <article class="card">
        <h3>Fast by default</h3>
        <p>Static site built with Astro. No sluggish ad-heavy layouts. 1&nbsp;MB JSON parses in under 200&nbsp;ms on modern devices.</p>
      </article>
      <article class="card">
        <h3>Private by design</h3>
        <p>All parsing and formatting runs on your device. Your code is never sent to our servers.</p>
      </article>
      <article class="card">
        <h3>More than a tool</h3>
        <p>Each format page ships with short guides and a glossary of related terms so you can learn while you work.</p>
      </article>
      <article class="card">
        <h3>Accessible &amp; mobile-friendly</h3>
        <p>Keyboard shortcuts, a proper dark mode, and a layout that works on your phone during a late-night debug session.</p>
      </article>
    </div>
  </section>

  <section class="container">
    <h2 class="section-h">Featured guides</h2>
    <div class="card-grid">
      {guides.map((g) => (
        <a class="card guide-card" href={`/guides/${g.id}/`}>
          <h3>{g.data.title}</h3>
          <p>{g.data.description}</p>
          <span class="card-arrow">Read →</span>
        </a>
      ))}
    </div>
    <p class="section-more">
      <a href="/guides/">Browse all guides</a> ·
      <a href="/glossary/">Glossary (30+ terms)</a> ·
      <a href="/faq/">FAQ</a>
    </p>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />

  <style>
    .section-h {
      text-align: center;
      margin: 2.5rem 0 1rem;
      font-size: 1.6rem;
    }
    .guide-card, .tool-card {
      display: block;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.12s, transform 0.12s;
    }
    .guide-card:hover, .tool-card:hover {
      border-color: var(--color-accent);
      transform: translateY(-1px);
      text-decoration: none;
    }
    .tools-grid { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
    .tool-card h3 { font-size: 1.25rem; margin-bottom: 0.4rem; }
    .reason-grid { margin-top: 1.5rem; }
    .card-arrow {
      color: var(--color-accent);
      font-weight: 600;
      font-size: 0.9rem;
    }
    .section-more {
      text-align: center;
      font-size: 0.95rem;
      color: var(--color-text-muted);
      margin-top: 1rem;
    }
    .section-more a { margin: 0 0.35rem; }
  </style>
</BaseLayout>
