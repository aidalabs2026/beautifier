---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE_URL } from '~/consts';

export async function getStaticPaths() {
  const terms = await getCollection('glossary');
  return terms.map((term) => ({
    params: { slug: term.id },
    props: { term },
  }));
}

const { term } = Astro.props;
const { Content } = await render(term);

const allTerms = await getCollection('glossary');
const relatedTerms = (term.data.related ?? [])
  .map((slug) => allTerms.find((t) => t.id === slug))
  .filter(<T,>(t: T | undefined): t is T => Boolean(t));

const formatted = term.data.lastUpdated.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonical = `/glossary/${term.id}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: term.data.title,
  description: term.data.description,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    name: 'Beautifier Glossary',
    url: new URL('/glossary/', SITE_URL).toString(),
  },
  url: new URL(canonical, SITE_URL).toString(),
};
---

<BaseLayout
  title={term.data.title}
  description={term.data.description}
  canonical={canonical}
>
  <article class="term">
    <div class="container-narrow">
      <header class="term-header">
        <a href="/glossary/" class="back-link">← All terms</a>
        <h1>{term.data.title}</h1>
        <p class="term-meta">Last updated {formatted}</p>
      </header>

      <div class="prose-content">
        <Content />
      </div>

      {relatedTerms.length > 0 && (
        <aside class="related">
          <h2>Related terms</h2>
          <ul>
            {relatedTerms.map((r) => (
              <li>
                <a href={`/glossary/${r.id}/`}>{r.data.title}</a>
                <span class="related-desc"> — {r.data.description}</span>
              </li>
            ))}
          </ul>
        </aside>
      )}

      <div class="cta-row">
        <a href="/glossary/" class="btn">Back to glossary</a>
        <a href="/json/" class="btn btn-primary">Open JSON tool</a>
      </div>
    </div>
  </article>

  <script
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />

  <style>
    .term { padding: 2rem 0 3rem; }
    .term-header { margin-bottom: 1.5rem; }
    .back-link {
      display: inline-block;
      color: var(--color-text-muted);
      font-size: 0.9rem;
      margin-bottom: 0.5rem;
    }
    .term-header h1 { margin: 0 0 0.25rem; font-size: 1.9rem; }
    .term-meta { color: var(--color-text-muted); font-size: 0.88rem; margin: 0; }

    .prose-content { font-size: 1.02rem; line-height: 1.72; }
    .prose-content h2 { margin-top: 1.8em; font-size: 1.25rem; }
    .prose-content p { margin: 0 0 1em; }
    .prose-content ul { padding-left: 1.5em; margin: 0 0 1em; }
    .prose-content pre {
      background: var(--color-code-bg);
      padding: 1em;
      border-radius: var(--radius);
      overflow-x: auto;
      font-size: 0.92em;
      border: 1px solid var(--color-border);
    }
    .prose-content code {
      font-family: var(--font-mono);
      background: var(--color-code-bg);
      padding: 0.1em 0.35em;
      border-radius: var(--radius-sm);
      font-size: 0.92em;
    }
    .prose-content pre code { background: transparent; padding: 0; }

    .related {
      margin-top: 2rem;
      padding: 1.25rem 1.5rem;
      background: var(--color-bg-alt);
      border-radius: var(--radius);
      border: 1px solid var(--color-border);
    }
    .related h2 { margin-top: 0; font-size: 1.05rem; }
    .related ul { list-style: none; padding: 0; margin: 0; }
    .related li { margin-bottom: 0.35rem; }
    .related a { font-weight: 600; }
    .related-desc { color: var(--color-text-muted); font-size: 0.92rem; }

    .cta-row { display: flex; gap: 0.75rem; margin: 2rem 0; flex-wrap: wrap; }
  </style>
</BaseLayout>
